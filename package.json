{
  "name": "commitism",
  "version": "0.1.0",
  "description": "A commit tool that actually handles hook failures",
  "type": "module",
  "bin": {
    "commitism": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "hooks",
    "pre-commit",
    "lint-staged",
    "ai",
    "groq",
    "conventional-commits",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "cleye": "^1.3.4",
    "execa": "^9.6.0",
    "groq-sdk": "^0.32.0",
    "ini": "^5.0.0",
    "kolorist": "^1.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.1"
  }
}

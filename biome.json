{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"files": {
		"includes": ["**"]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": {
						"maxAllowedComplexity": 15
					}
				},
				"noExcessiveLinesPerFunction": {
					"level": "warn",
					"options": {
						"maxLines": 50
					}
				}
			},
			"nursery": {
				"noExcessiveLinesPerFile": {
					"level": "warn",
					"options": {
						"maxLines": 400
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveCognitiveComplexity": "off",
						"noExcessiveLinesPerFunction": "off"
					},
					"nursery": {
						"noExcessiveLinesPerFile": {
							"level": "warn",
							"options": {
								"maxLines": 600
							}
						}
					}
				}
			}
		}
	]
}
